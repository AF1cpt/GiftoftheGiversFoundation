@model GiftGivers.Models.Donation

@{
    ViewData["Title"] = "Make a Donation";
}

<h1>Make a Donation</h1>
<h4>Your contribution matters.</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="DisasterId" class="control-label"></label>
                <select asp-for="DisasterId" class="form-control" asp-items="ViewBag.DisasterId"></select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ItemType" class="control-label"></label>
                <input asp-for="ItemType" class="form-control" placeholder="e.g., Canned Food, Blankets" />
                <span asp-validation-for="ItemType" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Donate" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>